{
  "name": "intro-tsl",
  "version": "2.0.0",
  "description": "Modern ThreeJS boilerplate powered by Vite & Typescript.",
  "keywords": [
    "3d",
    "three",
    "threejs",
    "tweakpane",
    "typescript",
    "vite"
  ],
  "homepage": "https://github.com/alvarosabu/modern-three#readme",
  "bugs": {
